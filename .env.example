# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=25
TELEGRAM_WEBHOOK_SECRET=

# Groq (транскрибация)
GROQ_API_KEY=your-groq-api-key
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_STT_LANGUAGE=ru

# GitHub (запись сидов в Cloud Run)
GITHUB_TOKEN=your-github-token
GITHUB_REPOSITORY=pashamal/seedintake
GITHUB_BRANCH=main
GITHUB_SEED_BASE_URL=https://github.com/pashamal/seedintake/blob/main

# Google Sheets
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json
GOOGLE_SHEET_ID=your-sheet-id

# Seed Pipeline
SEED_MARKDOWN_STORAGE=local
SEED_GOOGLE_WORKSPACE=mock
TRANSCRIPTION_PROVIDER=mock

# Cloud Run
PORT=8080
